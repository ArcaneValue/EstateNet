{
    "name": "estatenet-backend",
    "version": "1.0.0",
    "description": "Backend API for EstateNet property management",
    "main": "dist/index.js",
    "scripts": {
        "dev": "nodemon src/index.ts",
        "build": "npm run db:generate && tsc -p tsconfig.build.json",
        "postinstall": "prisma generate",
        "start": "node dist/index.js",
        "kill-server": "powershell -Command \"Get-Process | Where-Object {$_.ProcessName -like '*node*' -and $_.MainWindowTitle -like '*3001*'} | Stop-Process -Force\" 2>nul || echo No node processes on port 3001 found",
        "kill-server:all": "powershell -Command \"Get-Process -Name node -ErrorAction SilentlyContinue | Stop-Process -Force\" 2>nul || echo No node processes found",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:migrate": "prisma migrate dev",
        "db:studio": "prisma studio",
        "db:seed": "ts-node prisma/seed.ts",
        "seed:dev:tenant": "ts-node prisma/seed-dev-tenant.ts",
        "cleanup:duplicates": "ts-node src/scripts/runCleanup.ts",
        "setup:dev": "ts-node scripts/setupDevAccounts.ts",
        "db:reset": "prisma migrate reset --force",
        "test": "jest --runInBand"
    },
    "keywords": [
        "estate",
        "property",
        "management",
        "api",
        "typescript"
    ],
    "author": "EstateNet Team",
    "license": "MIT",
    "dependencies": {
        "@prisma/client": "^5.6.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/morgan": "^1.9.9",
        "@types/node": "^20.8.10",
        "@types/node-cron": "^3.0.11",
        "axios": "^1.14.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.3.1",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "node-cron": "^3.0.3",
        "nodemailer": "^6.9.7",
        "pdfkit": "^0.13.0",
        "prisma": "^5.6.0",
        "puppeteer": "^24.37.3",
        "typescript": "^5.2.2"
    },
    "devDependencies": {
        "@types/jest": "^29.5.5",
        "@types/nodemailer": "^8.0.0",
        "@types/pdfkit": "^0.17.5",
        "@types/supertest": "^2.0.12",
        "jest": "^29.7.0",
        "nodemon": "^3.0.1",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.1"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
