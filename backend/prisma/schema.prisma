generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phoneNumber  String?
  role         UserRole @default(TENANT)
  tenantId     String?  @unique
  profileImage String?
  notificationPrefs Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Manager payout fields
  payoutPhoneNumber String?
  payoutNetwork     String? // 'MTN' | 'AIRTEL'

  // Manager billing fields
  managerTermsAcceptedAt DateTime?
  billingStatus         String? // 'CURRENT' | 'OVERDUE'
  billingGraceUntil     DateTime?

  // Relations
  tenantIdentity TenantIdentity? @relation(fields: [tenantId], references: [tenantId])
  sentInvitations TenantInvitation[]
  sentMessages    Message[]       @relation("MessageFromUser")
  receivedMessages Message[]      @relation("MessageToUser")
  notifications    Notification[]
  ownedProperties Property[]    @relation("PropertyOwner")
  managedProperties Property[]  @relation("PropertyManager")
  ownerInvitations OwnerManagerInvitation[] @relation("OwnerInvitations")
  receivedManagerInvitations OwnerManagerInvitation[] @relation("ManagerInvitations")
  invoices     Invoice[]
  servicePayments ServicePayment[] @relation("ServicePayments")

  @@map("users")
}

model TenantIdentity {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  name         String
  email        String   @unique
  phoneNumber  String?
  profileImage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user User?
  leases Lease[]
  invitations TenantInvitation[]
  payments Payment[]

  @@map("tenant_identities")
}

enum UserRole {
  OWNER
  MANAGER
  TENANT
}

enum LeaseStatus {
  ACTIVE
  ENDED
  EVICTED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  PAID
  OVERDUE
}

model Property {
  id        String   @id @default(cuid())
  name      String
  location  String
  ownerId   String   // Property owner (required)
  managerId String?  // Assigned manager (optional)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  owner       User   @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  manager     User?  @relation("PropertyManager", fields: [managerId], references: [id], onDelete: SetNull)
  units       Unit[]
  leases      Lease[]
  invitations TenantInvitation[]
  payments    Payment[]
  ownerManagerInvitations OwnerManagerInvitation[]
  invoiceLines InvoiceLine[]

  @@map("properties")
}

model Unit {
  id         String   @id @default(cuid())
  propertyId String
  unitNumber String
  rentAmount Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases     Lease[]
  invitations TenantInvitation[]
  payments   Payment[]
  invoiceLines InvoiceLine[]

  @@unique([propertyId, unitNumber])
  @@map("units")
}

model Lease {
  id        String     @id @default(cuid())
  tenantId  String     // references TenantIdentity.tenantId (not the cuid)
  propertyId String
  unitId    String
  rentAmount Int
  startDate DateTime   @default(now())
  endDate   DateTime?
  status    LeaseStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenantIdentity TenantIdentity @relation(fields: [tenantId], references: [tenantId], onDelete: Restrict)
  messages       Message[]
  invoiceLines   InvoiceLine[]

  @@index([tenantId, status])
  @@map("leases")
}

model TenantInvitation {
  id          String           @id @default(cuid())
  tenantId    String
  propertyId  String
  unitId      String
  rentAmount  Int
  status      InvitationStatus @default(PENDING)
  invitedByUserId String       // manager user id
  createdAt   DateTime @default(now())
  respondedAt DateTime?

  // Relations
  tenantIdentity TenantIdentity @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  invitingUser   User           @relation(fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@map("tenant_invitations")
}

model Payment {
  id            String        @id @default(cuid())
  tenantId      String
  propertyId    String
  unitId        String
  amount        Int
  status        PaymentStatus @default(PENDING)
  paymentMethod String?
  transactionId String?
  paymentDate   DateTime
  dueDate       DateTime
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  tenantIdentity TenantIdentity @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  property       Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit           Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Message {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  leaseId    String?
  subject    String?
  body       String
  createdAt  DateTime @default(now())
  readAt     DateTime?
  archived   Boolean  @default(false)

  fromUser User  @relation("MessageFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User  @relation("MessageToUser", fields: [toUserId], references: [id], onDelete: Cascade)
  lease    Lease? @relation(fields: [leaseId], references: [id], onDelete: SetNull)

  @@index([toUserId, createdAt])
  @@index([fromUserId, createdAt])
  @@index([leaseId, createdAt])
  @@map("messages")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  metadata  Json?
  createdAt DateTime @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notifications")
}

model OwnerManagerInvitation {
  id          String           @id @default(cuid())
  propertyId  String
  ownerId     String
  managerEmail String
  managerId   String?          // Set when a manager accepts the invitation
  status      InvitationStatus @default(PENDING)
  createdAt   DateTime @default(now())
  respondedAt DateTime?

  // Relations
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  owner      User     @relation("OwnerInvitations", fields: [ownerId], references: [id], onDelete: Cascade)
  manager    User?    @relation("ManagerInvitations", fields: [managerId], references: [id], onDelete: SetNull)

  @@map("owner_manager_invitations")
}

model Invoice {
  id            String   @id @default(cuid())
  managerId     String
  periodStart   DateTime
  periodEnd     DateTime
  subtotalAmount Int
  feeRateBps    Int      // 399 = 3.99%
  feeAmount     Int
  status        String   // 'DUE' | 'PAID' | 'OVERDUE'
  dueDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  manager       User     @relation(fields: [managerId], references: [id])
  lines         InvoiceLine[]
  servicePayments ServicePayment[]

  @@unique([managerId, periodStart, periodEnd])
  @@map("invoices")
}

model InvoiceLine {
  id          String   @id @default(cuid())
  invoiceId   String
  propertyId  String
  unitId      String
  rentAmount  Int
  tenantId    String?
  leaseId     String?
  createdAt   DateTime @default(now())

  // Relations
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  property    Property @relation(fields: [propertyId], references: [id])
  unit        Unit     @relation(fields: [unitId], references: [id])
  lease       Lease?   @relation(fields: [leaseId], references: [id])

  @@map("invoice_lines")
}

model ServicePayment {
  id                String   @id @default(cuid())
  invoiceId         String
  managerId         String
  amount            Int
  currency          String   @default("UGX")
  provider          String   // 'MOCK' | 'YO'
  network           String   // 'MTN' | 'AIRTEL'
  phoneNumber       String
  externalRef       String   @unique
  providerRequestId String?
  providerTxId      String?
  status            String   @default("PENDING") // 'PENDING' | 'SUCCESS' | 'FAILED'
  failureReason     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  invoice           Invoice  @relation(fields: [invoiceId], references: [id])
  manager           User     @relation("ServicePayments", fields: [managerId], references: [id])

  @@map("service_payments")
}

model JobLock {
  id           String   @id @default(cuid())
  jobName      String   @unique
  lockedUntil  DateTime
  lockedBy     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("job_locks")
}
