# Flutterwave Payment Collection Configuration
FLW_PUBLIC_KEY=your_flutterwave_public_key_here
FLW_SECRET_KEY=your_flutterwave_secret_key_here
FLW_WEBHOOK_SECRET=your_webhook_secret_here

# Payment Provider Selection
# Options: 'mock' (for testing) or 'flutterwave' (for production)
PAYMENTS_PROVIDER=mock

# Database (existing)
DATABASE_URL=postgresql://username:password@localhost:5432/estatenet

# JWT (existing)
JWT_SECRET=your_jwt_secret_here
