# API Configuration
# LOCALHOST DEVELOPMENT - Using localhost for PC web browser
EXPO_PUBLIC_API_URL=http://localhost:3001/api

# Production backend URL (Render) - DISABLED FOR LOCAL TESTING
# EXPO_PUBLIC_API_URL=https://estatenet.onrender.com/api

# Hotspot IP for phone testing (switch to this when testing on phone)
