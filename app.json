{
  "expo": {
    "name": "EstateNet",
    "slug": "estatenet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1F3A5F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.estatenet.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1F3A5F"
      },
      "package": "com.estatenet.app",
      "buildToolsVersion": "34.0.0",
      "compileSdkVersion": 34,
      "targetSdkVersion": 34
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ],
    "owner": "jaxrabbit",
    "runtimeVersion": "1.0.0",
    "extra": {
      "eas": {
        "projectId": "37ccb684-7118-47a4-9282-64680a908487"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/37ccb684-7118-47a4-9282-64680a908487",
      "fallbackToCacheTimeout": 30000,
      "checkAutomatically": "ON_APP_LAUNCH",
      "enabled": true
    }
  }
}