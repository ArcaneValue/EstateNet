{
  "expo": {
    "name": "EstateNet",
    "slug": "estatenet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1F3A5F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.estatenet.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1F3A5F"
      },
      "package": "com.estatenet.app",
      "buildToolsVersion": "34.0.0",
      "compileSdkVersion": 34,
      "targetSdkVersion": 34
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "c176bd7c-58ed-4a4d-a0c7-4e664c976cd1"
      }
    },
    "owner": "muculezigeorge",
    "updates": {
      "url": "https://u.expo.dev/c176bd7c-58ed-4a4d-a0c7-4e664c976cd1"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}